{
	"name": "pi-garde-slop",
	"version": "0.1.0",
	"description": "Approve public GitHub CLI writes before Pi runs them.",
	"type": "module",
	"license": "ISC",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/lajarre/pi-garde-slop.git"
	},
	"bugs": {
		"url": "https://github.com/lajarre/pi-garde-slop/issues"
	},
	"homepage": "https://github.com/lajarre/pi-garde-slop#readme",
	"keywords": [
		"pi-package",
		"pi-extension",
		"github",
		"gh",
		"approval"
	],
	"files": [
		"extensions/",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"lint": "biome lint .",
		"format": "biome format --write .",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "node --test --test-concurrency=1 test/*.test.ts",
		"test:fixtures": "node --test --test-concurrency=1 test/command-policy.fixtures.ts",
		"check": "biome check . && npm run typecheck && npm test && npm run test:fixtures",
		"prepack": "npm run check"
	},
	"dependencies": {
		"just-bash": "^2.11.15"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@types/node": "^24.10.0",
		"lefthook": "^2.1.6",
		"typescript": "^5.9.3"
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": "*"
	},
	"pi": {
		"extensions": [
			"./extensions/github-write-approval/index.ts"
		]
	}
}
